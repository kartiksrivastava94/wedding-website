# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.

# --- Access codes (the "password" that branches guests into three groups) ---
# COCKTAIL      → invited to the Dec 1 cocktail (2 hosted nights: Dec 2, 3)
# COCKTAIL_STAY → invited to the Dec 1 cocktail AND Dec 1 night hosted (3 nights)
# MAIN          → everyone else (Dec 2–4). Codes are case-insensitive.
ACCESS_CODE_COCKTAIL=change-me-cocktail
ACCESS_CODE_COCKTAIL_STAY=change-me-cocktailstay
ACCESS_CODE_MAIN=change-me-main

# --- Cookie signing secret ---
# Any long random string. Generate one with:  openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# Password for the /admin RSVP dashboard.
ADMIN_PASSWORD=change-me-admin

# --- Supabase (RSVP database) ---
# From your Supabase project: Settings → API.
# The service role key is SECRET and server-only — never expose it to the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
